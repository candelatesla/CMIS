# CMIS Engagement Platform - Environment Variables Template
# Copy this file to .env and fill in your actual values

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/
MONGODB_DB_NAME=cmis_engagement

# Groq API Configuration (Get your API key from https://console.groq.com)
GROQ_API_KEY=your_groq_api_key_here

# N8N Webhook URL (Your N8N webhook endpoint for sending emails)
N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/your-webhook-id
